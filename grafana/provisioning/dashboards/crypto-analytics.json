        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "crypto-postgres"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "\nWITH latest AS (\n  SELECT DISTINCT ON (symbol) symbol, avg_price\n  FROM crypto_windowed\n  WHERE symbol IN (${symbol:singlequote})\n  ORDER BY symbol, updated_at DESC\n)\nSELECT symbol, avg_price FROM latest ORDER BY symbol;\n",
          "refId": "A"
        }
      ]
    },
