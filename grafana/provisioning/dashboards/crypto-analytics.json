          "rawQuery": true,
          "rawSql": "\nSELECT COALESCE(sum(total_volume), 0)::double precision AS latest_volume\nFROM (\n  SELECT DISTINCT ON (symbol) symbol, total_volume\n  FROM crypto_windowed\n  WHERE symbol IN (${symbol:singlequote})\n  ORDER BY symbol, updated_at DESC\n) latest;\n",
          "refId": "A"
        }
      ]
